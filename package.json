{
  "name": "@org/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "setup": "bash scripts/setup-dev.sh",
    "infra:up": "docker compose up -d postgres redis zookeeper kafka",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f",
    "kafka:topics": "bash scripts/create-kafka-topics.sh",
    "prisma:generate": "bash scripts/prisma-all.sh generate",
    "prisma:migrate": "bash scripts/prisma-all.sh migrate",
    "libs:build": "for lib in types decorators utils kafka-client exceptions; do pnpm exec tsc --project libs/shared/$lib/tsconfig.lib.json 2>/dev/null || true; done",
    "dev": "pnpm exec nx run-many --target=serve --projects=api-gateway,auth-service,user-service,market-service,trading-service,wallet-service,payment-service,notification-service,feed-service,admin-service,analytics-service --parallel=11",
    "dev:gateway": "pnpm exec nx serve api-gateway",
    "dev:auth": "pnpm exec nx serve auth-service",
    "dev:user": "pnpm exec nx serve user-service",
    "dev:market": "pnpm exec nx serve market-service",
    "dev:trading": "pnpm exec nx serve trading-service",
    "dev:wallet": "pnpm exec nx serve wallet-service",
    "dev:payment": "pnpm exec nx serve payment-service",
    "dev:notifications": "pnpm exec nx serve notification-service",
    "dev:feed": "pnpm exec nx serve feed-service",
    "dev:admin": "pnpm exec nx serve admin-service",
    "dev:analytics": "pnpm exec nx serve analytics-service",
    "typecheck": "bash scripts/typecheck-all.sh",
    "build:all": "pnpm exec nx run-many --target=build --all",
    "test:all": "pnpm exec nx run-many --target=test --all",
    "test:unit": "pnpm exec jest --config jest.unit.config.js",
    "test:unit:watch": "pnpm exec jest --config jest.unit.config.js --watch",
    "test:coverage": "pnpm exec jest --config jest.unit.config.js --coverage",
    "e2e": "pnpm exec jest --config apps/api-gateway-e2e/jest.config.cts --runInBand",
    "e2e:watch": "pnpm exec jest --config apps/api-gateway-e2e/jest.config.cts --runInBand --watch"
  },
  "private": true,
  "devDependencies": {
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nx/jest": "22.7.5",
    "@nx/js": "22.7.5",
    "@nx/nest": "^22.7.5",
    "@nx/node": "^22.7.5",
    "@nx/web": "22.7.5",
    "@nx/webpack": "22.7.5",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.8",
    "@swc/helpers": "0.5.18",
    "@swc/jest": "^0.2.37",
    "jest": "^29.7.0",
    "jest-circus": "^29.7.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "20.19.9",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/uuid": "^11.0.0",
    "nx": "22.7.5",
    "prettier": "^3.8.1",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@nestjs-modules/ioredis": "^2.2.1",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/microservices": "^11.1.26",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/platform-socket.io": "^11.1.26",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.26",
    "@prisma/client": "^6.19.3",
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/express": "^5.0.6",
    "axios": "^1.6.0",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "date-fns": "^4.4.0",
    "dayjs": "^1.11.21",
    "ioredis": "^5.11.1",
    "kafkajs": "^2.2.4",
    "nanoid": "^5.1.11",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "prisma": "^6.19.3",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^14.0.0"
  }
}
