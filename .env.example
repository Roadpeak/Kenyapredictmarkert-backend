# ─── Service Ports ────────────────────────────────────────────────────────────
GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
USER_SERVICE_PORT=3002
MARKET_SERVICE_PORT=3003
TRADING_SERVICE_PORT=3004
WALLET_SERVICE_PORT=3005
PAYMENT_SERVICE_PORT=3006
NOTIFICATION_SERVICE_PORT=3007
FEED_SERVICE_PORT=3008
ADMIN_SERVICE_PORT=3009
ANALYTICS_SERVICE_PORT=3010

# ─── Databases ────────────────────────────────────────────────────────────────
AUTH_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/auth_db
USER_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/user_db
MARKET_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/market_db
TRADING_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/trading_db
WALLET_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wallet_db
PAYMENT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/payment_db
NOTIFICATION_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/notification_db
ANALYTICS_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/analytics_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092

# ─── JWT (RS256) ──────────────────────────────────────────────────────────────
# Auto-generated by `pnpm setup` — or run:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Then paste as single-line with \n separating lines.
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── M-Pesa (Safaricom Daraja) ────────────────────────────────────────────────
# Sandbox values pre-filled — replace with production values before going live
MPESA_ENVIRONMENT=sandbox
MPESA_CONSUMER_KEY=your_consumer_key_from_developer_safaricom_com
MPESA_CONSUMER_SECRET=your_consumer_secret_from_developer_safaricom_com
MPESA_SHORT_CODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
# B2C: create initiator at developer.safaricom.co.ke → APIs → B2C → Security Credential
MPESA_B2C_INITIATOR_NAME=testapi
MPESA_B2C_SECURITY_CREDENTIAL=your_b2c_security_credential
# Callback URLs — must be publicly reachable by Safaricom (use ngrok in dev)
MPESA_CALLBACK_BASE_URL=https://your-ngrok-or-domain.com
MPESA_STK_CALLBACK_URL=https://your-ngrok-or-domain.com/api/callbacks/mpesa/stk
MPESA_B2C_RESULT_URL=https://your-ngrok-or-domain.com/api/callbacks/mpesa/b2c/result
MPESA_B2C_QUEUE_TIMEOUT_URL=https://your-ngrok-or-domain.com/api/callbacks/mpesa/b2c/timeout

# ─── Africa's Talking (OTP SMS) ───────────────────────────────────────────────
# In NODE_ENV=development, OTPs are logged to console — no AT credentials needed
AT_API_KEY=your_africastalking_api_key
AT_USERNAME=sandbox
AT_SENDER_ID=PREDICTMKT

# ─── Firebase Admin SDK (Push Notifications) ──────────────────────────────────
# Download service account JSON from Firebase Console → Project Settings → Service Accounts
# Paste the entire JSON as a single line (minified)
# In NODE_ENV=development, push is logged to console — no Firebase credentials needed
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"firebase-adminsdk@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# ─── Internal Service URLs (service-to-service) ───────────────────────────────
AUTH_SERVICE_URL=http://localhost:3001
USER_SERVICE_URL=http://localhost:3002
MARKET_SERVICE_URL=http://localhost:3003
TRADING_SERVICE_URL=http://localhost:3004
WALLET_SERVICE_URL=http://localhost:3005
PAYMENT_SERVICE_URL=http://localhost:3006
NOTIFICATION_SERVICE_URL=http://localhost:3007
FEED_SERVICE_URL=http://localhost:3008
ADMIN_SERVICE_URL=http://localhost:3009
ANALYTICS_SERVICE_URL=http://localhost:3010

# ─── Internal API Key (service-to-service auth) ───────────────────────────────
INTERNAL_API_KEY=change-me-in-production-use-a-random-64-char-string

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_NAME=PredictMarket
